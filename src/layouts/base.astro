---
import "../styles/global.css";

const {
  title = "Arbor & Algo - Tech build to last and grow",
  description = "Independent tech practice based in India. Websites, automation, integrations and advisory for businesses that want to build on strong foundations.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  </head>
  <body>
    <div class="site-shell">
      <slot />
    </div>
  </body>
</html>
