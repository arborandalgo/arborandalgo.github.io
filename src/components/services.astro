---
const services = [
  {
    title: "Websites & web apps",
    body: "A professional home for your business, or a full product your customers use every day. Built to perform and straightforward to manage.",
    eg: "e.g. booking systems, service portals, dashboards",
  },
  {
    title: "Business automation",
    body: "The admin work that eats your week, running quietly in the background. You focus on the business.",
    eg: "e.g. invoicing, inventory, lead tracking",
  },
  {
    title: "Integrations & connections",
    body: "Your existing tools, talking to each other. Payments, logistics, messaging, CRM. No platform overhaul required.",
    eg: "e.g. Razorpay, Shiprocket, Zoho, WhatsApp",
  },
  {
    title: "Tech advisory",
    body: "Unsure where to start, or whether what you have is actually working? I'll help you see clearly before you spend on the wrong thing.",
    eg: "e.g. audits, roadmaps, vendor guidance",
  },
];
---

<section id="services" class="split-section animate-rise delay-3">
  <p class="section-label">What I build</p>

  <div class="section-content">
    <div class="services-grid">
      {
        services.map(({ title, body, eg }) => (
          <article class="service-card">
            <h3>{title}</h3>
            <p>{body}</p>
            <small>{eg}</small>
          </article>
        ))
      }
    </div>
  </div>
</section>
