---
const beliefs = [
  {
    mark: "Roots",
    heading: "Business context over feature checklists",
    body: "The decisions are grounded in your goals, constraints, and customer reality. Generic stack templates don't survive contact with a real business.",
  },
  {
    mark: "Trunk",
    heading: "Clarity is a quality requirement.",
    body: "Architecture, naming, boundaries. Kept understandable so the system stays usable long after launch, by people who weren't there when it was built.",
  },
  {
    mark: "Canopy",
    heading: "Ownership should stay with your team.",
    body: "The work is designed to be picked up, extended, and handed off. You shouldn't need me on speed dial to keep things running.",
  },
];
---

<section class="split-section animate-rise delay-2">
  <p class="section-label">Belief</p>

  <div class="section-content">
    <div class="belief-list">
      {
        beliefs.map(({ mark, heading, body }) => (
          <article class="belief-item">
            <h3>
              <span>{mark}</span>
              {heading}
            </h3>
            <p>{body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
