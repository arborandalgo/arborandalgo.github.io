---
const points = [
  {
    title: "Clear architecture",
    body: "The build starts from your business model. The systems stay legible as the team and product grow.",
  },
  {
    title: "Practical handoff",
    body: "Every project ships with enough structure and documentation that a future developer can step in without needing a long explanation.",
  },
  {
    title: "Focused collaboration",
    body: "I keep the client list small on purpose. Decisions get proper thought, communication stays direct.",
  },
];
---

<section id="approach" class="split-section animate-rise delay-2">
  <p class="section-label">Approach</p>

  <div class="section-content">
    <div class="approach-grid">
      {
        points.map(({ title, body }) => (
          <article class="approach-item">
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
